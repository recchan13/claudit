{
  "name": "@marchev/claudit",
  "version": "0.1.15",
  "description": "MCP server for searching Solodit smart contract security findings",
  "type": "module",
  "bin": {
    "claudit": "dist/index.js"
  },
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc && chmod +x dist/index.js",
    "start": "node dist/index.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "solodit",
    "smart-contracts",
    "security",
    "auditing",
    "claude-code"
