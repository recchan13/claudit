  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/marchev/claudit.git"
  },
  "homepage": "https://github.com/marchev/claudit",
  "bugs": {
    "url": "https://github.com/marchev/claudit/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.4"
  },
  "devDependencies": {
    "@types/node": "^20.17.50",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=18"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
